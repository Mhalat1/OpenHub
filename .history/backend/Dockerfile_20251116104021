FROM php:8.3-apache

# Installer les dépendances PHP
RUN apt-get update && apt-get install -y \
    git unzip libicu-dev libzip-dev libpng-dev zip \
    libonig-dev curl && \
    docker-php-ext-install intl pdo pdo_mysql gd zip opcache mbstring && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Activer les modules Apache nécessaires
RUN a2enmod rewrite headers

WORKDIR /var/www/html

# Copier les fichiers du projet
COPY . .

# Installer Composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

# Installer les dépendances PHP
RUN composer install --no-dev --optimize-autoloader --no-scripts

# Configurer Apache pour servir /public
ENV APACHE_DOCUMENT_ROOT /var/www/html/public
RUN sed -ri -e 's!/var/www/html!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/sites-available/*.conf
RUN sed -ri -e 's!/var/www/!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/apache2.conf /etc/apache2/conf-available/*.conf
RUN sed -i '/<Directory \/var\/www\/html\/public>/,/<\/Directory>/ s/AllowOverride None/AllowOverride All/' /etc/apache2/apache2.conf

# Copier les clés JWT dans le container et sécuriser les permissions
RUN mkdir -p /var/www/html/config/jwt
COPY config/jwt/*.pem /var/www/html/config/jwt/
RUN chmod 600 /var/www/html/config/jwt/*.pem && chown -R www-data:www-data /var/www/html/config/jwt/

EXPOSE 80#!/usr/bin/env bash
set -e

echo "🏗️  Building app for Render..."

# Créer le dossier JWT si inexistant
mkdir -p config/jwt

# Injecter les clés depuis les variables Render
echo "$JWT_SECRET_KEY" > config/jwt/private.pem
echo "$JWT_PUBLIC_KEY" > config/jwt/public.pem

# Sécuriser les permissions
chmod 600 config/jwt/*.pem

# Installer les dépendances
composer install --no-dev --optimize-autoloader --no-interaction

# Build cache Symfony
php bin/console cache:clear --no-warmup

echo "✅ Build terminé."


# Commande finale
CMD php bin/console cache:clear --no-warmup && apache2-foreground

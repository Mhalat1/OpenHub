FROM php:8.2-apache

# ... vos étapes existantes ...

WORKDIR /var/www/html

# Copier l'application
COPY . .

# Créer les répertoires de cache et logs
RUN mkdir -p var/cache var/log var/storage

# Corriger les permissions AVANT composer install
RUN chown -R www-data:www-data var/
RUN chmod -R 775 var/

# Installer les dépendances
RUN composer install --no-dev --optimize-autoloader

# Réappliquer les permissions après composer install
RUN chown -R www-data:www-data var/
RUN chmod -R 775 var/

# Vider et préchauffer le cache avec le bon utilisateur
RUN php bin/console cache:clear --no-warmup
RUN php bin/console cache:warmup

# Configuration Apache
RUN a2enmod rewrite
COPY .docker/apache.conf /etc/apache2/sites-available/000-default.conf

# Définir le propriétaire final
RUN chown -R www-data:www-data /var/www/html/

CMD ["apache2-foreground"]
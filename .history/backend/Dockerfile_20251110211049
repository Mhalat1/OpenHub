FROM php:8.3-apache

# Installer les dépendances système et extensions PHP
RUN apt-get update && apt-get install -y \
    git unzip libicu-dev libzip-dev libpng-dev zip \
    libonig-dev curl && \
    docker-php-ext-install intl pdo pdo_mysql gd zip opcache mbstring

# Activer les modules Apache nécessaires
RUN a2enmod rewrite headers

# Définir le répertoire de travail
WORKDIR /var/www/html

# Copier tous les fichiers du projet
COPY . .

# Installer Composer et dépendances PHP
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer
RUN composer install --no-dev --optimize-autoloader --no-scripts

# Configurer Apache pour Render
ENV APACHE_DOCUMENT_ROOT /var/www/html/public
RUN sed -ri -e 's!/var/www/html!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/sites-available/*.conf
RUN sed -ri -e 's!/var/www/!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/apache2.conf /etc/apache2/conf-available/*.conf

# Copier le script de démarrage Render et le rendre exécutable
COPY render-start.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/render-start.sh

# Créer le dossier var et régler les permissions
RUN mkdir -p /var/www/html/var
RUN chown -R www-data:www-data /var/www/html/var
RUN chmod -R 755 /var/www/html/var

# Exposer le port HTTP
EXPOSE 80

# Commande de démarrage
CMD ["/usr/local/bin/render-start.sh"]
